# =============================================================================
# Intent Engine - Environment Configuration
# =============================================================================
# Privacy-First Intent-Driven Advertising Platform
# 
# Setup Instructions:
# 1. Copy this file: cp .env.example .env
# 2. Update values for your environment
# 3. Never commit .env files to version control
#
# Environment Profiles:
#   - development: Local development with debug features
#   - staging: Pre-production testing environment
#   - production: Live production environment
# =============================================================================

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------
# Environment: development, staging, production
ENVIRONMENT=development

# Application name for logging and monitoring
APP_NAME=intent-engine

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Number of worker processes (auto-detected if not set)
WORKERS=4

# Logging Level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log format: json, console
LOG_FORMAT=console

# -----------------------------------------------------------------------------
# Database Configuration (PostgreSQL)
# -----------------------------------------------------------------------------
# Full database URL (overrides individual settings if set)
# Format: postgresql://user:password@host:port/database
# DATABASE_URL=postgresql://intent_user:password@localhost:5432/intent_engine

# Individual database settings (used if DATABASE_URL not set)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=intent_engine
POSTGRES_USER=intent_user
POSTGRES_PASSWORD=change_this_password_in_production

# Connection Pool Settings
# Adjust based on expected concurrent connections
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=1800

# PgBouncer Settings (optional connection pooling)
PGBOUNCER_ENABLED=false
PGBOUNCER_HOST=localhost
PGBOUNCER_PORT=6543

# -----------------------------------------------------------------------------
# Database Configuration (SQLite - Development Only)
# -----------------------------------------------------------------------------
# Uncomment to use SQLite for local development instead of PostgreSQL
# DATABASE_URL=sqlite:///./intent_engine.db

# -----------------------------------------------------------------------------
# Redis Cache Configuration
# -----------------------------------------------------------------------------
# Enable Redis for distributed caching and session management
REDIS_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379/0

# Redis Pool Settings
REDIS_MAX_CONNECTIONS=50
REDIS_TIMEOUT=5.0

# SSL/TLS for Redis (production)
REDIS_SSL=false
REDIS_SSL_CERT_REQS=none

# -----------------------------------------------------------------------------
# Security Configuration
# -----------------------------------------------------------------------------
# IMPORTANT: Generate a secure random key for production!
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-this-to-a-secure-random-string-in-production

# JWT Token Settings
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS Configuration
ENABLE_CORS=true
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Authorization,Content-Type,X-Requested-With,X-Correlation-ID
CORS_EXPOSE_HEADERS=X-Correlation-ID,X-Request-Id
CORS_MAX_AGE=600

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_STRICT=10/minute
RATE_LIMIT_STORAGE_URL=memory://

# -----------------------------------------------------------------------------
# SearXNG Integration (Privacy-Focused Search)
# -----------------------------------------------------------------------------
SEARXNG_ENABLED=true
SEARXNG_BASE_URL=http://localhost:8080
SEARXNG_SECRET_KEY=generate-with-openssl-rand-hex-32
SEARXNG_LIMITER=false
SEARXNG_IMAGE_PROXY=true
SEARXNG_URL=https://searxng.example.com

# SearXNG Search Categories
SEARXNG_CATEGORIES=general,images,videos,news,science

# -----------------------------------------------------------------------------
# Authentication & Authorization
# -----------------------------------------------------------------------------
# OAuth2 Providers (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=

# API Key Authentication
API_KEY_HEADER=X-API-Key
API_KEY=

# -----------------------------------------------------------------------------
# ML Model Configuration
# -----------------------------------------------------------------------------
# Model cache directory
MODEL_CACHE_DIR=./model_cache

# Sentence Transformers Model
SENTENCE_TRANSFORMERS_MODEL=all-MiniLM-L6-v2
SENTENCE_TRANSFORMERS_DEVICE=cpu

# Transformers Cache
TRANSFORMERS_CACHE=./transformers_cache

# Hugging Face Token (for private models)
HUGGING_FACE_TOKEN=

# -----------------------------------------------------------------------------
# Privacy & Compliance (GDPR)
# -----------------------------------------------------------------------------
# Data Retention Settings (in hours)
SESSION_DATA_RETENTION_HOURS=8
ANALYTICS_DATA_RETENTION_DAYS=90
AUDIT_LOG_RETENTION_DAYS=365

# Consent Management
CONSENT_REQUIRED=true
CONSENT_EXPIRY_DAYS=365

# Anonymization
ENABLE_ANONYMIZATION=true
ANONYMIZATION_SALT=generate-random-salt-for-anonymization

# -----------------------------------------------------------------------------
# Monitoring & Observability
# -----------------------------------------------------------------------------
# Prometheus Metrics
ENABLE_METRICS=true
METRICS_PORT=9090
PROMETHEUS_URL=http://localhost:9090

# Grafana
GRAFANA_URL=http://localhost:3000
GRAFANA_USER=admin
GRAFANA_PASSWORD=change_this_grafana_password

# Health Check Settings
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_TIMEOUT=10

# Distributed Tracing (optional)
TRACING_ENABLED=false
TRACING_ENDPOINT=http://localhost:4317
TRACING_SERVICE_NAME=intent-engine

# -----------------------------------------------------------------------------
# Background Tasks (ARQ Worker)
# -----------------------------------------------------------------------------
ARQ_WORKER_ENABLED=true
ARQ_WORKER_CONCURRENCY=5
ARQ_WORKER_MAX_JOBS=100

# -----------------------------------------------------------------------------
# Email Configuration (Optional - for notifications)
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_TLS=true
SMTP_FROM_EMAIL=noreply@intent-engine.local

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
FEATURE_NEW_RANKING_ALGORITHM=false
FEATURE_ADVANCED_FRAUD_DETECTION=true
FEATURE_A_B_TESTING=true
FEATURE_REAL_TIME_ANALYTICS=true

# -----------------------------------------------------------------------------
# Development Overrides
# -----------------------------------------------------------------------------
# Enable hot reload (development only)
RELOAD=true

# Enable debug mode (do not use in production)
DEBUG=false

# Disable SSL verification (development only)
SSL_VERIFY=false

# -----------------------------------------------------------------------------
# Production Settings (Reference)
# -----------------------------------------------------------------------------
# These are examples - set actual values in production environment
#
# DATABASE_URL=postgresql+asyncpg://user:secure-password@db.example.com:5432/intent_engine
# REDIS_URL=rediss://:secure-password@redis.example.com:6379/0
# SECRET_KEY=<generate-with-python-secrets-token-urlsafe-32>
# POSTGRES_PASSWORD=<secure-database-password>
# GRAFANA_PASSWORD=<secure-grafana-password>
# SEARXNG_SECRET_KEY=<generate-with-openssl-rand-hex-32>
# ANONYMIZATION_SALT=<random-salt-string>
# =============================================================================
